# ======================================================================
# AI Engineering Team — backend configuration
# Copy to `.env` and adjust. Every value below has a sensible default,
# so the stack runs out of the box in MOCK mode with no API keys.
# ======================================================================

# --- Core ---
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database ---
# SQLite (default, zero-config). For Postgres use e.g.:
# DATABASE_URL=postgresql+asyncpg://aiteam:aiteam@localhost:5432/aiteam
DATABASE_URL=sqlite+aiosqlite:///./aiteam.db

# --- LLM provider ---
# One of: mock | anthropic | openai
# `mock` is fully deterministic and requires no API keys — ideal for demos.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# --- Orchestration ---
# Maximum review/refine iterations before the graph finalizes regardless.
MAX_ITERATIONS=2
# Per-agent LLM retry attempts on transient failures.
AGENT_MAX_RETRIES=2
# Artificial latency (seconds) injected by the mock provider so the live
# activity feed feels real during demos. Set to 0 for instant runs.
MOCK_LATENCY_SECONDS=0.6
