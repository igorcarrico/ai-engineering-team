# Normalize line endings: LF in the repo, auto-converted on checkout.
* text=auto eol=lf

# Windows scripts keep CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as binary (no EOL conversion, no diff noise).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.pdf binary
