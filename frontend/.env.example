# Frontend configuration (all optional — sensible defaults baked in).

# Where the browser sends API calls. Defaults to same-origin "/api", which Next
# proxies to the backend (see next.config.mjs). Override only for split deploys.
# NEXT_PUBLIC_API_BASE=/api

# Backend URL the Next dev/prod server proxies to (server-side).
BACKEND_INTERNAL_URL=http://localhost:8000
