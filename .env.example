# ======================================================================
# Root environment for docker-compose. Copy to `.env`.
# Everything defaults to a key-free mock run.
# ======================================================================

# LLM provider: mock | anthropic | openai
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Mock provider latency (seconds) — controls the live-feed pacing.
MOCK_LATENCY_SECONDS=0.6

# Postgres credentials (used by the compose stack).
POSTGRES_USER=aiteam
POSTGRES_PASSWORD=aiteam
POSTGRES_DB=aiteam
